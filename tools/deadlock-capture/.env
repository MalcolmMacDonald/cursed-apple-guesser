# Copy this file to .env and fill in the values.
# Bun automatically reads .env in the current directory.

# ── Required ──────────────────────────────────────────────────────────────────

# The RCON password you set in Deadlock's Steam launch options.
# In Steam: right-click Deadlock → Properties → Launch Options →
#   -console -rcon_password yourpassword
RCON_PASSWORD=malva

# Full path to the directory where Deadlock saves screenshots.
# In Steam: View → Recordings and Screenshots → right-click any screenshot
# → Show on Disk, then copy the folder path.
# Deadlock's Steam App ID is 1422450, so the path is usually:
#   C:\Program Files (x86)\Steam\userdata\<steamid>\760\remote\1422450\screenshots
GAME_SCREENSHOT_DIR=C:\Program Files (x86)\Steam\userdata\39175365\760\remote\1422450\screenshots

# ── Optional (shown with defaults) ────────────────────────────────────────────

# RCON host. Change only if running on a different machine.
# RCON_HOST=127.0.0.1

# RCON port. Usually 27015 for Deadlock.
# RCON_PORT=27015

# How long (ms) to wait after setpos before taking a screenshot.
# Increase if screenshots are taken while the scene is still loading.
# TELEPORT_DELAY_MS=1500

# Maximum time (ms) to wait for the game to create a new screenshot file.
# SCREENSHOT_TIMEOUT_MS=8000

# Override the output directory for captured screenshots.
# Defaults to public/locations/ at the repo root (auto-detected).
# OUTPUT_DIR=
