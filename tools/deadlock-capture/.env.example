# Copy this file to .env and fill in the values.
# Bun automatically reads .env in the current directory.

# ── Required ──────────────────────────────────────────────────────────────────

# The RCON password you set in Deadlock's Steam launch options.
# In Steam: right-click Deadlock → Properties → Launch Options →
#   -console -rcon_password yourpassword
RCON_PASSWORD=

# Parent directory where Deadlock saves screenshots.
# Screenshots are saved in date-based subdirectories (e.g. 2024-06-01/screenshot_0001.jpg).
# The tool watches this directory recursively for new .jpg files.
GAME_SCREENSHOT_DIR=

# ── Optional (shown with defaults) ────────────────────────────────────────────

# RCON host. Change only if running on a different machine.
# RCON_HOST=127.0.0.1

# RCON port. Usually 27015 for Deadlock.
# RCON_PORT=27015

# Maximum time (ms) to wait for a screenshot file before dropping a pending capture.
# SCREENSHOT_TIMEOUT_MS=8000

# ── Session capture settings ─────────────────────────────────────────────────

# Interval (ms) between automatic captures during a session.
# SESSION_INTERVAL_MS=1000

# Maximum number of unresolved screenshots before skipping ticks (backpressure).
# MAX_PENDING=3

# Output directory for capture sessions.
# Each session creates a subdirectory with a manifest and screenshots.
# SESSION_OUTPUT_DIR=./output/sessions
